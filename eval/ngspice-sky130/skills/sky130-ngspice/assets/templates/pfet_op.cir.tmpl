* Sky130 PFET operating-point probe
.include "{sky130_lib}"

Vdd vdd 0 1.8
Vd vdd d 0.9
Vg vdd g 0.9

Xp d g vdd vdd sky130_fd_pr__pfet_01v8 w=1.26 l=0.15

.op
.control
run
let gm=@m.xp.msky130_fd_pr__pfet_01v8[gm]
let gds=@m.xp.msky130_fd_pr__pfet_01v8[gds]
let gmbs=@m.xp.msky130_fd_pr__pfet_01v8[gmbs]
let gain_int=gm/gds
print gm gds gmbs gain_int v(d) v(g) v(vdd)
.endc

.end

