* Sky130 common-source operating-point probe
.include "{sky130_lib}"

Vdd vdd 0 1.8
Vin in 0 0.9
Rd vdd out 20k

Xn out in 0 0 sky130_fd_pr__nfet_01v8 w=1.26 l=0.15

.op
.control
run
let gm=@m.xn.msky130_fd_pr__nfet_01v8[gm]
let gds=@m.xn.msky130_fd_pr__nfet_01v8[gds]
let gain_est=-gm/(gds+1/20000)
print gm gds gain_est v(out)
.endc

.end

